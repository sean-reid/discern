# ============================================================
# Discern: Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Image Source API Keys (free tiers) ---
# Unsplash: https://unsplash.com/developers (50 req/hr free)
UNSPLASH_ACCESS_KEY=

# Pexels: https://www.pexels.com/api/ (200 req/month free)
PEXELS_API_KEY=


# --- Cloudflare R2 (S3-compatible API) ---
# Get these from Cloudflare dashboard > R2 > Manage R2 API Tokens
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=discern-images

# --- Cloudflare D1 (REST API for local scripts) ---
# Used by seed scripts to write to D1 from your local machine.
# Get the API token from Cloudflare dashboard > My Profile > API Tokens
CF_ACCOUNT_ID=
D1_API_URL=https://api.cloudflare.com/client/v4
D1_API_TOKEN=
D1_DATABASE_ID=

# --- Next.js Public ---
NEXT_PUBLIC_IMAGE_BASE_URL=https://your-r2-public-url.example.com
